# ==========================================
# Shiftlink — Production Environment Template
# ==========================================

# Application
NODE_ENV=production
PORT=3000
APP_ORIGIN=https://your-domain.com

# Optional: Additional allowed CORS origins (comma-separated)
# ALLOWED_ORIGINS=https://app.your-domain.com,https://admin.your-domain.com

# Database
DATABASE_URL=postgresql://shiftlink:change-me-to-a-strong-password@db:5432/shiftlink?schema=public

# Redis
REDIS_URL=redis://redis:6379

# JWT
JWT_SECRET=change-me-to-a-32-char-min-secret-change-me!
JWT_EXPIRES_IN=7d

# S3 / MinIO
S3_ENDPOINT=minio:9000
S3_REGION=eu-central-1
S3_BUCKET=shiftlink-private
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_FORCE_PATH_STYLE=true
S3_SIGNED_URL_TTL_SECONDS=900

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Auth Rate Limiting (stricter, for login/register endpoints)
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=10

# Frontend (build-time)
VITE_API_BASE_URL=/api/v1
VITE_BASE_PATH=/

# WhatsApp (optional)
WHATSAPP_PROVIDER=mock
# WHATSAPP_FROM_NUMBER=
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
