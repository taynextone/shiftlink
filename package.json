{
  "name": "shiftlink",
  "version": "1.0.0",
  "description": "Digitaler Matching-Marktplatz f\u00fcr kurzfristige Pflegeeins\u00e4tze in Krankenh\u00e4usern, mit Fokus auf Direktvermittlung statt Zeitarbeit.",
  "main": "dist/server.js",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "test": "jest --runInBand",
    "prisma:generate": "prisma generate --config prisma.config.ts",
    "web:dev": "vite --config web/vite.config.ts",
    "web:build": "npm --prefix web run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/taynextone/shiftlink.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/taynextone/shiftlink/issues"
  },
  "homepage": "https://github.com/taynextone/shiftlink#readme",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1047.0",
    "@aws-sdk/s3-request-presigner": "^3.1047.0",
    "@prisma/client": "^7.8.0",
    "argon2": "^0.44.0",
    "bullmq": "^5.76.8",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.1.0",
    "http-errors": "^2.0.1",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.15.1",
    "zod": "^4.4.3"
  },
  "private": true,
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/express-rate-limit": "^5.1.3",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.8.0",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@types/supertest": "^7.2.0",
    "@vitejs/plugin-react": "^6.0.2",
    "jest": "^30.4.2",
    "prisma": "^7.8.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "ts-node-dev": "^2.0.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.14"
  }
}
