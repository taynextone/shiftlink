generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  NURSE
  HOSPITAL_ADMIN
  SUPER_ADMIN
}

enum VerificationStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum JobShiftStatus {
  OPEN
  MATCHED
  CANCELED
}

enum MatchContractStatus {
  PENDING
  DECLINED
  SIGNED
  EXPIRED
  CANCELED
}

enum InvoiceStatus {
  PENDING
  PAID
}

enum RequirementPriority {
  REQUIRED
  PREFERRED
}

enum ShiftPreference {
  DAY
  NIGHT
  EARLY
  LATE
  FLEXIBLE
}

enum VerificationDocumentType {
  EXAMEN
  SPECIALIZATION_CERTIFICATE
  OCCUPATIONAL_HEALTH_CLEARANCE
}

enum VerificationDocumentStatus {
  PENDING
  VERIFIED
  REJECTED
}


enum ContractExecutionStatus {
  DRAFT
  PENDING_HOSPITAL_SIGNATURE
  PENDING_NURSE_SIGNATURE
  FULLY_EXECUTED
  VOIDED
}

enum ContractSignerRole {
  HOSPITAL_ADMIN
  NURSE
  SUPER_ADMIN
}

model User {
  id                 String             @id @default(cuid())
  email              String             @unique
  passwordHash       String
  role               UserRole
  verificationStatus VerificationStatus @default(PENDING)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  nurseProfile       NurseProfile?
  hospitalProfile    HospitalProfile?

  @@index([role])
  @@index([verificationStatus])
}

model NurseProfile {
  id                      String                   @id @default(cuid())
  userId                  String                   @unique
  publicId                String                   @unique
  displayName             String
  firstName               String
  lastName                String
  iban                    String
  minHourlyRate           Decimal                  @default(42.00) @db.Decimal(10, 2)
  phoneNumber             String
  whatsappOptIn           Boolean                  @default(false)
  examenFileUrl           String?
  preferredShiftType      ShiftPreference          @default(FLEXIBLE)
  minAssignmentHours      Int?
  maxAssignmentHours      Int?
  preferredRegionsNote    String?
  isReleasedForMatching   Boolean                  @default(false)
  releasedAt              DateTime?
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  user                    User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  matchContracts          MatchContract[]
  specializations         NurseSpecialization[]
  verificationDocuments   VerificationDocument[]
  availabilityBlocks      NurseAvailabilityBlock[]

  @@index([lastName, firstName])
  @@index([phoneNumber])
  @@index([publicId])
}

model NurseSpecialization {
  id             String       @id @default(cuid())
  nurseProfileId String
  tag            String
  createdAt      DateTime     @default(now())
  nurseProfile   NurseProfile @relation(fields: [nurseProfileId], references: [id], onDelete: Cascade)

  @@unique([nurseProfileId, tag])
  @@index([tag])
}

model NurseAvailabilityBlock {
  id                    String       @id @default(cuid())
  nurseProfileId        String
  title                 String?
  city                  String
  postalCode            String?
  latitude              Decimal?     @db.Decimal(9, 6)
  longitude             Decimal?     @db.Decimal(9, 6)
  radiusKm              Int
  startTime             DateTime
  endTime               DateTime
  isBooked              Boolean      @default(false)
  notes                 String?
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt
  nurseProfile          NurseProfile @relation(fields: [nurseProfileId], references: [id], onDelete: Cascade)

  @@index([nurseProfileId])
  @@index([city])
  @@index([startTime, endTime])
  @@index([isBooked])
}

model HospitalProfile {
  id               String                @id @default(cuid())
  userId           String                @unique
  clinicName       String
  billingAddress   String
  taxNumber        String
  webhookUrl       String?
  webhookSecret    String?
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  user             User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobShifts        JobShift[]
  webhookEvents    WebhookEvent[]

  @@index([clinicName])
}

model JobShift {
  id                       String                @id @default(cuid())
  hospitalProfileId        String
  externalJobShiftId       String?
  title                    String?
  department               String?
  stationName              String?
  locationCity             String?
  locationPostalCode       String?
  locationLatitude         Decimal?              @db.Decimal(9, 6)
  locationLongitude        Decimal?              @db.Decimal(9, 6)
  startTime                DateTime
  endTime                  DateTime
  totalPlannedHours        Decimal               @db.Decimal(6, 2)
  status                   JobShiftStatus        @default(OPEN)
  createdAt                DateTime              @default(now())
  updatedAt                DateTime              @updatedAt
  hospitalProfile          HospitalProfile       @relation(fields: [hospitalProfileId], references: [id], onDelete: Cascade)
  matchContracts           MatchContract[]
  requirements             JobShiftRequirement[]

  @@index([hospitalProfileId])
  @@unique([hospitalProfileId, externalJobShiftId])
  @@index([status])
  @@index([startTime, endTime])
  @@index([locationCity])
}

model JobShiftRequirement {
  id          String              @id @default(cuid())
  jobShiftId  String
  tag         String
  priority    RequirementPriority
  createdAt   DateTime            @default(now())
  jobShift    JobShift            @relation(fields: [jobShiftId], references: [id], onDelete: Cascade)

  @@index([jobShiftId])
  @@index([tag])
}

model MatchContract {
  id                    String                @id @default(cuid())
  jobShiftId            String
  nurseProfileId        String
  status                MatchContractStatus   @default(PENDING)
  expiresAt             DateTime?
  respondedAt           DateTime?
  signedAt              DateTime?
  contractPdfUrl        String?
  executionStatus       ContractExecutionStatus @default(DRAFT)
  fullyExecutedAt       DateTime?
  currentSnapshotId     String?               @unique
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  jobShift              JobShift              @relation(fields: [jobShiftId], references: [id], onDelete: Cascade)
  nurseProfile          NurseProfile          @relation(fields: [nurseProfileId], references: [id], onDelete: Cascade)
  currentSnapshot       ContractSnapshot?     @relation("CurrentContractSnapshot", fields: [currentSnapshotId], references: [id], onDelete: SetNull)
  contractSnapshots     ContractSnapshot[]    @relation("MatchContractSnapshots")
  signatureEvents       ContractSignatureEvent[]
  voidEvent             ContractVoidEvent?
  invoice               Invoice?

  @@unique([jobShiftId, nurseProfileId])
  @@index([status])
  @@index([executionStatus])
  @@index([signedAt])
  @@index([fullyExecutedAt])
  @@index([nurseProfileId])
  @@index([jobShiftId, status])
}

model Invoice {
  id                String        @id @default(cuid())
  matchContractId   String        @unique
  amount            Decimal       @db.Decimal(10, 2)
  status            InvoiceStatus @default(PENDING)
  invoicePdfUrl     String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  matchContract     MatchContract @relation(fields: [matchContractId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([createdAt])
}

model WebhookEvent {
  id                String   @id @default(cuid())
  hospitalProfileId String
  eventType         String
  payloadJson       String
  deliveryAttempts  Int      @default(0)
  lastAttemptAt     DateTime?
  deliveredAt       DateTime?
  lastError         String?
  createdAt         DateTime @default(now())
  hospitalProfile   HospitalProfile @relation(fields: [hospitalProfileId], references: [id], onDelete: Cascade)

  @@index([hospitalProfileId, createdAt])
  @@index([eventType])
  @@index([deliveredAt, createdAt])
}

model VerificationDocument {
  id                String                     @id @default(cuid())
  nurseProfileId    String
  documentType      VerificationDocumentType
  fileUrl           String
  status            VerificationDocumentStatus @default(PENDING)
  reviewerUserId    String?
  reviewedAt        DateTime?
  rejectionReason   String?
  createdAt         DateTime                   @default(now())
  updatedAt         DateTime                   @updatedAt
  nurseProfile      NurseProfile               @relation(fields: [nurseProfileId], references: [id], onDelete: Cascade)

  @@index([nurseProfileId, documentType])
  @@index([status])
}

model ContractSnapshot {
  id                String        @id @default(cuid())
  matchContractId   String
  version           Int
  snapshotJson      String
  summaryText       String
  createdAt         DateTime      @default(now())
  matchContract     MatchContract @relation("MatchContractSnapshots", fields: [matchContractId], references: [id], onDelete: Cascade)
  currentFor        MatchContract? @relation("CurrentContractSnapshot")

  @@unique([matchContractId, version])
  @@index([matchContractId, createdAt])
}

model ContractSignatureEvent {
  id                    String                  @id @default(cuid())
  matchContractId       String
  signerUserId          String
  signerRole            ContractSignerRole
  snapshotId            String?
  signatureIntent       String
  signatureEvidenceJson String
  createdAt             DateTime                @default(now())
  matchContract         MatchContract           @relation(fields: [matchContractId], references: [id], onDelete: Cascade)

  @@unique([matchContractId, signerUserId])
  @@index([matchContractId, createdAt])
  @@index([matchContractId, signerRole, createdAt])
  @@index([signerUserId, createdAt])
  @@index([snapshotId])
}

model ContractVoidEvent {
  id                String        @id @default(cuid())
  matchContractId   String        @unique
  actorUserId       String
  actorRole         ContractSignerRole
  reason            String
  evidenceJson      String
  createdAt         DateTime      @default(now())
  matchContract     MatchContract @relation(fields: [matchContractId], references: [id], onDelete: Cascade)

  @@index([actorUserId, createdAt])
  @@index([actorRole, createdAt])
  @@index([createdAt])
}


model AsyncProcessFailure {
  id             String   @id @default(cuid())
  queueName      String
  jobName        String
  jobId          String?
  relatedEntityId String?
  attemptCount   Int?
  errorMessage   String
  createdAt      DateTime @default(now())

  @@index([queueName, createdAt])
  @@index([relatedEntityId])
  @@index([createdAt])
}

